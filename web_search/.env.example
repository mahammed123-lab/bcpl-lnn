# ─────────────────────────────────────────────────────────────
# JARVIS Search Gate — environment config
#
# YOU DO NOT NEED ALL OF THESE. Copy this file to `.env` and fill in
# ONLY the keys you actually have. The gate auto-detects whatever is
# present and routes around whatever is missing:
#   - Any ONE search key (Tavily / Serper / SerpAPI / SearXNG / NewsData)
#     is enough for web search to work.
#   - Any ONE LLM key (NVIDIA / Groq / OpenRouter / Together / Gemini)
#     or a local Ollama URL is enough for classification + answers.
# Minimum viable setup: ONE search key + ONE LLM key = 2 lines total.
# ─────────────────────────────────────────────────────────────

# ── Web search providers (need at least one) ──
TAVILY_API_KEY=
SERPER_API_KEY=
SERPAPI_API_KEY=
NEWSDATA_API_KEY=
# SearXNG needs no key — self-host or use a public instance:
SEARXNG_URL=
SEARXNG_PREFERENCES=

# ── LLM providers — for the "does this need a search" classifier AND
#    for turning raw search results into a written answer.
#    Need at least one. First one below with a key set (in priority
#    order) is used; if it fails, the next one is tried automatically. ──
NVIDIA_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
GEMINI_API_KEY=
# Local Ollama (no key, just a running `ollama serve`):
OLLAMA_BASE_URL=

# ── Optional: override default models per provider ──
# NVIDIA_MODEL=meta/llama-3.2-3b-instruct
# GROQ_MODEL=llama-3.1-8b-instant
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# TOGETHER_MODEL=meta-llama/Llama-3.2-3B-Instruct-Turbo
# GEMINI_MODEL=gemini-1.5-flash
# OLLAMA_MODEL=llama3.2

# ── Optional: change the LLM fallback order (comma-separated) ──
# LLM_PROVIDER_PRIORITY=nvidia,groq,openrouter,together,gemini,ollama

# ── Optional: general behaviour tuning ──
# JARVIS_KNOWLEDGE_CUTOFF=unknown — treat any date-sensitive fact as possibly stale
# JARVIS_FAILURE_THRESHOLD=3
# JARVIS_COOLDOWN_SECONDS=300
# JARVIS_SESSION_TTL=600
# JARVIS_LLM_CLASSIFIER=1
# JARVIS_SYNTH_TOKENS=800
# JARVIS_SYNTH_TIMEOUT=12
